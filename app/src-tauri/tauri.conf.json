{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PromptForge",
  "version": "0.1.0",
  "identifier": "com.promptforge.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PromptForge",
        "width": 900,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https: http:; img-src 'self' data:; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5QUU4QTE4MDc5OTQ3NzMKUldSelI1a0hHSXF1eVFIZ1hWUGZDTDdOVFRVNzB2R1VtN09zcDNzYThCdGI2UU5zTVJGWENJMW4K",
      "endpoints": [
        "https://github.com/gaowei90098-creator/PromptForge/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
